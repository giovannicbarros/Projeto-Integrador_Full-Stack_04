// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Fornecedor {
  id               Int      @id @default(autoincrement())
  nomeEmpresa      String   @map("nome_empresa") @db.VarChar(150)
  cnpj             String   @unique @db.VarChar(14)
  logradouro       String   @db.VarChar(150)
  numero           String   @db.VarChar(10)
  bairro           String   @db.VarChar(100)
  cidade           String   @db.VarChar(100)
  uf               String   @db.VarChar(2)
  cep              String   @db.VarChar(8)
  telefone         String   @db.VarChar(11)
  email            String   @db.VarChar(150)
  contatoPrincipal String   @map("contato_principal") @db.VarChar(150)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("fornecedores")
}

model Produto {
  id                Int       @id @default(autoincrement())
  nome              String    @db.VarChar(150)
  codigoBarras      String?   @unique @map("codigo_barras") @db.VarChar(20)
  descricao         String    @db.Text
  quantidadeEstoque Int       @default(0) @map("quantidade_estoque")
  categoria         String    @db.VarChar(100)
  dataValidade      DateTime? @map("data_validade")
  imagemBase64      String?   @map("imagem_base64") @db.LongText
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("produtos")
}
